+	clk_disable_unprepare(dec->hclk_info.clk);
+	clk_disable_unprepare(dec->core_clk_info.clk);
+	clk_disable_unprepare(dec->cabac_clk_info.clk);
+	clk_disable_unprepare(dec->hevc_cabac_clk_info.clk);
+
+	return 0;
+}
