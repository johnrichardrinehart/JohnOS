+	MPP_DEVICE_VDPU2	= 1, /* 0x00000002 */
+	MPP_DEVICE_VDPU1_PP	= 2, /* 0x00000004 */
+	MPP_DEVICE_VDPU2_PP	= 3, /* 0x00000008 */
