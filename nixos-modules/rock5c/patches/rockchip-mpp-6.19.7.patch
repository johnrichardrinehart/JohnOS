+struct vdpp_hw_info {
+	struct mpp_hw_info hw;
+
+	/* register info */
+	u32 start_base;
+	u32 cfg_base;
+	u32 work_mode_base;
+	u32 gate_base;
+	u32 rst_sta_base;
+	u32 int_en_base;
+	u32 int_clr_base;
+	u32 int_sta_base; // int_sta = int_raw_sta && int_en
+	u32 int_mask;
+	u32 err_mask;
+	/* register for zme */
+	u32 zme_reg_off;
+	u32 zme_reg_num;
+	/* for soft reset */
+	u32 bit_rst_en;
+	u32 bit_rst_done;
+};
