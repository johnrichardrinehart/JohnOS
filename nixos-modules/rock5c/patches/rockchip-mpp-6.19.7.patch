+	if (!dec)
+		return NOTIFY_OK;
+
+	if (event == DEVFREQ_PRECHANGE)
+		mutex_lock(&dec->sip_reset_lock);
+	else if (event == DEVFREQ_POSTCHANGE)
+		mutex_unlock(&dec->sip_reset_lock);
+
+	return NOTIFY_OK;
+}
