+	MPP_DEVICE_HEVC_DEC	= 8, /* 0x00000100 */
+	MPP_DEVICE_RKVDEC	= 9, /* 0x00000200 */
+	MPP_DEVICE_AVSPLUS_DEC	= 12, /* 0x00001000 */
+	MPP_DEVICE_RKJPEGD	= 13, /* 0x00002000 */
+
+	MPP_DEVICE_RKVENC	= 16, /* 0x00010000 */
+	MPP_DEVICE_VEPU1	= 17, /* 0x00020000 */
