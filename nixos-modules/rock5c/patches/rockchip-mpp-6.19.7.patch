+	mpp_procfs_create_u32("session_buffers", 0644,
+			      dec->procfs, &mpp->session_max_buffers);
+	proc_create_single("perf_sel_offset", 0444,
+			   dec->procfs, rkvdec2_show_pref_sel_offset);
+	mpp_procfs_create_u32("task_count", 0644,
