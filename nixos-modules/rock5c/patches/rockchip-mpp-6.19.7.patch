+#define to_vdpp_info(info)	\
+		container_of(info, struct vdpp_hw_info, hw)
+#define to_vdpp_task(task)	\
+		container_of(task, struct vdpp_task, mpp_task)
+#define to_vdpp_dev(dev)	\
+		container_of(dev, struct vdpp_dev, mpp)
