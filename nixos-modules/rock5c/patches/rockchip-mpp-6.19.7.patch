+	mpp_clk_safe_enable(dec->aclk_info.clk);
+	mpp_clk_safe_enable(dec->hclk_info.clk);
+	mpp_clk_safe_enable(dec->core_clk_info.clk);
+	mpp_clk_safe_enable(dec->cabac_clk_info.clk);
