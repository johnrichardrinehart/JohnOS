+static int rkvdec_3328_exit(struct mpp_dev *mpp)
+{
+	struct rkvdec_dev *dec = to_rkvdec_dev(mpp);
+
+	if (dec->aux_page)
+		__free_page(dec->aux_page);
+
+	if (dec->aux_iova != -1) {
+		iommu_unmap(mpp->iommu_info->domain, dec->aux_iova, IOMMU_PAGE_SIZE);
+		dec->aux_iova = -1;
+	}
+	rkvdec_devfreq_remove(mpp);
+
+	return 0;
