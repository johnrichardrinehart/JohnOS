+#define	VDPP_SESSION_MAX_BUFFERS	15
+#define VDPP_REG_WORK_MODE			0x0008
+#define VDPP_REG_VDPP_MODE			BIT(1)
+#define VDPP_GET_VDPP_MODE(x)			((x) & 0x2)
+
