+#define VDPU1_REG_STREAM_RLC_BASE	0x030
+#define VDPU1_REG_STREAM_RLC_BASE_INDEX	(12)
+
+#define VDPU1_REG_DIR_MV_BASE		0x0a4
+#define VDPU1_REG_DIR_MV_BASE_INDEX	(41)
+
+#define VDPU1_REG_CLR_CACHE_BASE	0x810
