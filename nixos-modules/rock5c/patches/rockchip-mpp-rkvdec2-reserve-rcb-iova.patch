diff --git a/drivers/video/rockchip/mpp/mpp_iommu.c b/drivers/video/rockchip/mpp/mpp_iommu.c
index 6221cb7a6fa4b..7f57874145398 100644
--- a/drivers/video/rockchip/mpp/mpp_iommu.c
+++ b/drivers/video/rockchip/mpp/mpp_iommu.c
@@ -688,6 +688,8 @@ int mpp_iommu_reserve_iova(struct mpp_iommu_info *info, dma_addr_t iova, size_t
 {
 
 	struct iommu_domain *domain;
+	struct mpp_iommu_dma_cookie *cookie;
+	struct iova *existing;
 	struct iova_domain *iovad;
 	unsigned long pfn_lo, pfn_hi;
 
@@ -698,13 +700,36 @@ int mpp_iommu_reserve_iova(struct mpp_iommu_info *info, dma_addr_t iova, size_t
 	if (!domain || !domain->iova_cookie)
 		return -EINVAL;
 
+	cookie = (struct mpp_iommu_dma_cookie *)domain->iova_cookie;
 	iovad = mpp_iommu_dma_cookie_iovad(domain->iova_cookie);
+	if (!iovad->granule) {
+		dev_err(info->dev,
+			"reserve_iova invalid allocator state: domain=%px cookie=%px iovad=%px granule=%lu iova=%pad size=%zu\n",
+			domain, cookie, iovad, iovad->granule, &iova, size);
+		return -EINVAL;
+	}
 
 	/* iova will be freed automatically by put_iova_domain() */
 	pfn_lo = iova_pfn(iovad, iova);
 	pfn_hi = iova_pfn(iovad, iova + size - 1);
-	if (!reserve_iova(iovad, pfn_lo, pfn_hi))
+	dev_info(info->dev,
+		 "reserve_iova domain=%px cookie=%px iovad=%px granule=%lu iova=%pad size=%zu pfn=[%#lx-%#lx]\n",
+		 domain, cookie, iovad, iovad->granule, &iova, size, pfn_lo, pfn_hi);
+	existing = find_iova(iovad, pfn_lo);
+	if (existing &&
+	    pfn_lo >= existing->pfn_lo &&
+	    pfn_hi <= existing->pfn_hi) {
+		dev_info(info->dev,
+			 "reserve_iova already reserved iova=%pad pfn=[%#lx-%#lx] existing=[%#lx-%#lx]\n",
+			 &iova, pfn_lo, pfn_hi, existing->pfn_lo, existing->pfn_hi);
+		return 0;
+	}
+	if (!reserve_iova(iovad, pfn_lo, pfn_hi)) {
+		dev_err(info->dev,
+			"reserve_iova failed iova=%pad size=%zu pfn=[%#lx-%#lx]\n",
+			&iova, size, pfn_lo, pfn_hi);
 		return -EINVAL;
+	}
 
 	return 0;
 
