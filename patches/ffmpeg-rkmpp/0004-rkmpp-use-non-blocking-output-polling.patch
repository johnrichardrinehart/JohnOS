From 22ae44df382b5f82bc8cbd90dc0c0273b7c662e9 Mon Sep 17 00:00:00 2001
From: John Rinehart <johnrichardrinehart@gmail.com>
Date: Fri, 3 Apr 2026 21:00:52 -0400
Subject: [PATCH] avcodec/rkmppdec: use non-blocking output polling

---
 libavcodec/rkmppdec.c | 18 ++++--------------
 1 file changed, 4 insertions(+), 14 deletions(-)

diff --git a/libavcodec/rkmppdec.c b/libavcodec/rkmppdec.c
index e182783..e32e332 100644
--- a/libavcodec/rkmppdec.c
+++ b/libavcodec/rkmppdec.c
@@ -41,7 +41,6 @@
 #include "libavutil/log.h"
 #include "libavutil/mem.h"
 
-#define RECEIVE_FRAME_TIMEOUT   100
 #define FRAMEGROUP_MAX_FRAMES   16
 typedef struct {
     MppCtx ctx;
@@ -158,7 +157,6 @@ static av_cold int rkmpp_init_decoder(AVCodecContext *avctx)
     MppCodingType codectype = MPP_VIDEO_CodingUnused;
     enum AVPixelFormat pix_fmts[3] = { AV_PIX_FMT_DRM_PRIME, AV_PIX_FMT_NONE, AV_PIX_FMT_NONE };
     int ret;
-    RK_S64 paramS64;
     RK_S32 paramS32;
 
     switch (avctx->pix_fmt) {
@@ -218,23 +216,15 @@ static av_cold int rkmpp_init_decoder(AVCodecContext *avctx)
         goto fail;
     }
 
-    // make decode calls blocking with a timeout
-    paramS32 = MPP_POLL_BLOCK;
+    // Use non-blocking output polling so the receive loop can drain frames
+    // without injecting long stalls when no frame is ready yet.
+    paramS32 = MPP_POLL_NON_BLOCK;
     ret = decoder->mpi->control(decoder->ctx, MPP_SET_OUTPUT_BLOCK, &paramS32);
     if (ret != MPP_OK) {
-        av_log(avctx, AV_LOG_ERROR, "Failed to set blocking mode on MPI (code = %d).\n", ret);
+        av_log(avctx, AV_LOG_ERROR, "Failed to set non-blocking mode on MPI (code = %d).\n", ret);
         ret = AVERROR_UNKNOWN;
         goto fail;
     }
-
-    paramS64 = RECEIVE_FRAME_TIMEOUT;
-    ret = decoder->mpi->control(decoder->ctx, MPP_SET_OUTPUT_BLOCK_TIMEOUT, &paramS64);
-    if (ret != MPP_OK) {
-        av_log(avctx, AV_LOG_ERROR, "Failed to set block timeout on MPI (code = %d).\n", ret);
-        ret = AVERROR_UNKNOWN;
-        goto fail;
-    }
-
     ret = mpp_buffer_group_get_internal(&decoder->frame_group, MPP_BUFFER_TYPE_ION);
     if (ret) {
        av_log(avctx, AV_LOG_ERROR, "Failed to retrieve buffer group (code = %d)\n", ret);
-- 
2.51.2

