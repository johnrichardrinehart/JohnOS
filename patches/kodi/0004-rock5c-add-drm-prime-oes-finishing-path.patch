+GLint CRendererDRMPRIMEGLES::GetCurrentUniformLocation(const char* name) const
+{
+  GLint program = 0;
+  glGetIntegerv(GL_CURRENT_PROGRAM, &program);
+  if (program <= 0)
+    return -1;
+
+  return glGetUniformLocation(static_cast<GLuint>(program), name);
+}
