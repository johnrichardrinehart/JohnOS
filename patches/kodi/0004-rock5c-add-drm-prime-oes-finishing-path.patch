+
+bool IsDRMPRIMETraceEnabled()
+{
+  const char* value = std::getenv("KODI_DRMPRIME_TRACE");
+  return value && *value && std::strcmp(value, "0") != 0;
+}
+
+int GetOESDebugMode()
+{
+  const char* value = std::getenv("KODI_DRMPRIME_OES_DEBUG");
+  if (!value || !*value)
+    return 0;
+
+  if (std::strcmp(value, "raw") == 0 || std::strcmp(value, "1") == 0)
+    return 1;
+  if (std::strcmp(value, "post-bc") == 0 || std::strcmp(value, "2") == 0)
+    return 2;
+  if (std::strcmp(value, "expanded") == 0 || std::strcmp(value, "3") == 0)
+    return 3;
+  if (std::strcmp(value, "pq-linear") == 0 || std::strcmp(value, "4") == 0)
+    return 4;
+  if (std::strcmp(value, "tonemapped") == 0 || std::strcmp(value, "5") == 0)
+    return 5;
+
+  return 0;
+}
+
+const char* OESDebugModeString(int mode)
+{
+  switch (mode)
+  {
+    case 1:
+      return "raw-sample";
+    case 2:
+      return "post-brightness-contrast";
+    case 3:
+      return "post-range-expansion";
+    case 4:
+      return "pq-linear-preview";
+    case 5:
+      return "post-tonemap";
+    default:
+      return "normal";
+  }
+}
+
+float GetFloatEnv(const char* name, float fallback)
+{
+  const char* value = std::getenv(name);
+  if (!value || !*value)
+    return fallback;
+
+  char* end = nullptr;
+  const float parsed = std::strtof(value, &end);
+  if (end == value)
+    return fallback;
+
+  return parsed;
+}
