diff --git a/drivers/gpu/drm/i915/display/intel_hotplug.c b/drivers/gpu/drm/i915/display/intel_hotplug.c
index 4451a792600a0..d7a85628720eb 100644
--- a/drivers/gpu/drm/i915/display/intel_hotplug.c
+++ b/drivers/gpu/drm/i915/display/intel_hotplug.c
@@ -1173,6 +1173,21 @@ bool intel_hpd_schedule_detection(struct intel_display *display)
 	return ret;
 }

+bool intel_hpd_schedule_detection_delayed(struct intel_display *display,
+					  unsigned long delay_ms)
+{
+	unsigned long flags;
+	bool ret;
+
+	spin_lock_irqsave(&display->irq.lock, flags);
+	ret = queue_delayed_detection_work(display,
+					   &display->hotplug.hotplug_work,
+					   msecs_to_jiffies(delay_ms));
+	spin_unlock_irqrestore(&display->irq.lock, flags);
+
+	return ret;
+}
+
 static int i915_hpd_storm_ctl_show(struct seq_file *m, void *data)
 {
 	struct intel_display *display = m->private;
diff --git a/drivers/gpu/drm/i915/display/intel_hotplug.h b/drivers/gpu/drm/i915/display/intel_hotplug.h
index edc41c9d3d65f..975d28e909b7c 100644
--- a/drivers/gpu/drm/i915/display/intel_hotplug.h
+++ b/drivers/gpu/drm/i915/display/intel_hotplug.h
@@ -34,5 +34,7 @@ void intel_hpd_debugfs_register(struct intel_display *display);
 void intel_hpd_enable_detection_work(struct intel_display *display);
 void intel_hpd_disable_detection_work(struct intel_display *display);
 bool intel_hpd_schedule_detection(struct intel_display *display);
+bool intel_hpd_schedule_detection_delayed(struct intel_display *display,
